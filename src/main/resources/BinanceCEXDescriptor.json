										{"name":"filterType", "type": "STRING", "description":"Price filter, see <a href=\"https://binance-docs.github.io/apidocs/spot/en/#filters\">API</a> documentation.", "sampleValue": "true"},
										{"name":"minPrice", "type": "BIGDECIMAL", "description":"Provided with PRICE_FILTER filter type", "sampleValue": "0.00000100"},
										{"name":"maxPrice", "type": "BIGDECIMAL", "description":"Provided with PRICE_FILTER filter type", "sampleValue": "100000.00000000"},
										{"name":"tickSize", "type": "BIGDECIMAL", "description":"Provided with PRICE_FILTER filter type", "sampleValue": "0.00000100"}
