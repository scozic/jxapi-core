					"description": "Close out a user data stream..<br/>See <a href=\"https://binance-docs.github.io/apidocs/spot/en/#listen-key-spot\">API</a><br/>Remark: This API is used internally by websocket wrapper, which creates, keeps alive and eventually refreshes listeny key.",
					"url": "https://api.binance.com/api/v3/userDataStream",
					"queryParams": true,
					"parameters": [
						{"name":"listenKey", "type": "STRING", "description":"", "sampleValue": "pqia91ma19a5s61cv6a81va65sdf19v8a65a1a5s61cv6a81va65sdf19v8a65a1"}
					],
					"response": [
					]
