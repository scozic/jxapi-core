						{"msgField":"P", "name":"priceChangePercent", "type": "BIGDECIMAL", "description":"Price change percent.", "sampleValue":"250.00"},
						{"msgField":"o", "name":"openPrice","type": "BIGDECIMAL", "description":"Open price.", "sampleValue":"0.0010"},
						{"msgField":"h", "name":"highPrice", "type": "BIGDECIMAL", "description":"High price.", "sampleValue":"0.0025"},
						{"msgField":"l", "name":"lowPrice", "type": "BIGDECIMAL", "description":"Low price.", "sampleValue":"0.010"},
						{"msgField":"c", "name":"lastPrice", "type": "BIGDECIMAL", "description":"Last price", "sampleValue":"0.0025"},
						{"msgField":"w", "name":"weightedAvgPrice", "type": "BIGDECIMAL", "description":"Weighted average price.", "sampleValue":"0.0018"},
						{"msgField":"v", "name":"baseAssetVolume", "type": "BIGDECIMAL", "description":"Total traded base asset volume.", "sampleValue":"10000"},
						{"msgField":"q", "name":"quoteAssetVolume", "type": "BIGDECIMAL", "description":"Total traded quote asset volume.", "sampleValue":"18"},
						{"msgField":"O", "name":"openTime", "type": "TIMESTAMP", "description":"Statistics open time.", "sampleValue":"0"},
						{"msgField":"C", "name":"closeTime", "type": "TIMESTAMP", "description":"Statistics close time.", "sampleValue":"86400000"},
						{"msgField":"F", "name":"firstTradeID", "type": "LONG", "description":"First trade ID.", "sampleValue":"0"},
