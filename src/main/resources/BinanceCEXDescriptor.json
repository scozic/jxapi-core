								{"name":"permissions", "type": "STRING_LIST", "description":"", "sampleValue": "[\"SPOT\", \"MARGIN]\""},
								{"name":"defaultSelfTradePreventionMode", "type": "STRING", "description":"", "sampleValue": "NONE"},
								{"name":"allowedSelfTradePreventionModes", "type": "STRING_LIST", "description":"", "sampleValue": "[\"NONE\"]"}
							]
						}
					]
				},
				{
					"name": "exchangeInformation",
					"httpMethod": "GET",
					"description": "Current exchange trading rules and symbol information for a list of spot trading pairs.<br/>See <a href=\"https://binance-docs.github.io/apidocs/spot/en/#exchange-information\">API</a>",
					"url": "https://api.binance.com/api/v3/exchangeInfo",
					
