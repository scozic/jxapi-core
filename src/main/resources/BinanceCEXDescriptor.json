								{"name":"cancelReplaceAllowed", "type": "BOOLEAN", "description":"", "sampleValue": "true"},
								{"name":"isSpotTradingAllowed", "type": "BOOLEAN", "description":"", "sampleValue": "true"},
								{"name":"isMarginTradingAllowed", "type": "BOOLEAN", "description":"", "sampleValue": "true"},
