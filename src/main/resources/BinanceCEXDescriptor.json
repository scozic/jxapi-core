								{"name":"ocoAllowed", "type": "BOOLEAN", "description":"True if OCO orders are allowed", "sampleValue": "true"},
								{"name":"quoteOrderQtyMarketAllowed", "type": "BOOLEAN", "description":"", "sampleValue": "true"},
								{"name":"allowTrailingStop", "type": "BOOLEAN", "description":"True if trailing stop orders are supported", "sampleValue": "true"},
								{"name":"cancelReplaceAllowed", "type": "BOOLEAN", "description":"", "sampleValue": "true"},
								{"name":"isSpotTradingAllowed", "type": "BOOLEAN", "description":"", "sampleValue": "true"},
								{"name":"isMarginTradingAllowed", "type": "BOOLEAN", "description":"", "sampleValue": "true"},
