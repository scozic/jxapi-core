				{
					"name": "IndividualSymbolTickerStreams",
					"topic": "${symbol}@ticker",
					"description": "24hr rolling window ticker statistics for a single symbol. These are NOT the statistics of the UTC day, but a 24hr rolling window for the previous 24hrs.<br/>See <a href=\"https://binance-docs.github.io/apidocs/spot/en/#individual-symbol-ticker-streams\">API</a>",
