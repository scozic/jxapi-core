								{"name":"symbol", "type": "STRING", "description":"Market symbol", "sampleValue":"BTCUSDT"},
								{"name":"status", "type": "STRING", "description":"Current trading status", "sampleValue":"TRADING"},
								{"name":"baseAsset", "type": "STRING", "description":"Market base asset that is bought with buy order", "sampleValue":"BTC"},
