								{"name":"quoteAssetPrecision", "type": "INT", "description":"Quote asset precision", "sampleValue": "8"},
								{"name":"orderTypes", "type": "STRING_LIST", "description":"Quote asset precision", "sampleValue": "[\"LIMIT\", \"MARKET\"]"},
